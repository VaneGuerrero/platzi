{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://platzi.local/contracts/ai-radar-daily-search.schema.json",
  "title": "AI Radar Daily Search",
  "description": "Contrato para guardar una busqueda diaria de senales de AI Radar.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contractVersion",
    "radar",
    "search",
    "signals"
  ],
  "properties": {
    "contractVersion": {
      "type": "string",
      "description": "Version semantica del contrato usado por el snapshot diario.",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "radar": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "description"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "search": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "query",
        "runDate",
        "timezone",
        "language",
        "requestedFormat",
        "sourcePolicy"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "query": { "type": "string", "minLength": 1 },
        "runDate": { "type": "string", "format": "date" },
        "timezone": { "type": "string", "minLength": 1 },
        "language": { "type": "string", "minLength": 2 },
        "requestedFormat": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "enum": ["fuente", "evidencia", "impacto", "accion", "estado"] }
        },
        "sourcePolicy": { "type": "string", "minLength": 1 }
      }
    },
    "signals": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/signal" }
    }
  },
  "$defs": {
    "signal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "category",
        "source",
        "evidence",
        "impact",
        "action",
        "status"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "category": { "type": "string", "minLength": 1 },
        "source": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "publisher", "url", "type"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "publisher": { "type": "string", "minLength": 1 },
            "url": { "type": "string", "format": "uri" },
            "type": { "type": "string", "enum": ["news", "analysis", "report", "index"] }
          }
        },
        "evidence": {
          "type": "object",
          "additionalProperties": false,
          "required": ["summary", "observations"],
          "properties": {
            "summary": { "type": "string", "minLength": 1 },
            "observations": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            }
          }
        },
        "impact": {
          "type": "object",
          "additionalProperties": false,
          "required": ["level", "summary", "affectedAreas"],
          "properties": {
            "level": { "type": "string", "enum": ["low", "medium", "high", "very_high"] },
            "summary": { "type": "string", "minLength": 1 },
            "affectedAreas": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            }
          }
        },
        "action": {
          "type": "object",
          "additionalProperties": false,
          "required": ["recommendation", "nextSteps"],
          "properties": {
            "recommendation": { "type": "string", "minLength": 1 },
            "nextSteps": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            }
          }
        },
        "status": {
          "type": "object",
          "additionalProperties": false,
          "required": ["label", "stage", "confidence"],
          "properties": {
            "label": { "type": "string", "minLength": 1 },
            "stage": { "type": "string", "enum": ["watch", "alert", "active", "developing", "strategic_exploration"] },
            "confidence": { "type": "string", "enum": ["low", "medium", "high"] }
          }
        }
      }
    }
  }
}
